{
  "name": "pixelstream",
  "version": "2.0.0",
  "description": "Experience Visual Innovation in High Definition - A cutting-edge video generation platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "prepare": "husky install",
    "deploy:pages": "gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/U-A-S/PixelStream.git"
  },
  "keywords": [
    "video-generation",
    "hd-video",
    "typography-animation",
    "ai-video",
    "pixelstream",
    "media-processing"
  ],
  "author": "Umair Abbas Siddiquie",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/U-A-S/PixelStream/issues"
  },
  "homepage": "https://u-a-s.github.io/PixelStream",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "sharp": "^0.33.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.0",
    "gh-pages": "^6.1.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,md,json}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
